<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Travel Planner Platform API</display-name>

    <!-- CORS Filter -->
    <filter>
        <filter-name>CorsFilter</filter-name>
        <filter-class>com.travelplanner.filter.CorsFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CorsFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Authentication Servlet -->
    <servlet>
        <servlet-name>AuthServlet</servlet-name>
        <servlet-class>com.travelplanner.servlet.AuthServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuthServlet</servlet-name>
        <url-pattern>/api/auth/*</url-pattern>
    </servlet-mapping>

    <!-- Destination Servlet -->
    <servlet>
        <servlet-name>DestinationServlet</servlet-name>
        <servlet-class>com.travelplanner.servlet.DestinationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DestinationServlet</servlet-name>
        <url-pattern>/api/destinations/*</url-pattern>
    </servlet-mapping>

    <!-- Trip Servlet -->
    <servlet>
        <servlet-name>TripServlet</servlet-name>
        <servlet-class>com.travelplanner.servlet.TripServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TripServlet</servlet-name>
        <url-pattern>/api/trips/*</url-pattern>
    </servlet-mapping>

    <!-- Admin Servlet -->
    <servlet>
        <servlet-name>AdminServlet</servlet-name>
        <servlet-class>com.travelplanner.servlet.AdminServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/api/admin/*</url-pattern>
    </servlet-mapping>

    <!-- Session configuration (30 minutes) -->
    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
            <!-- SameSite config is handled programmatically or left to default -->
        </cookie-config>
    </session-config>

</web-app>
